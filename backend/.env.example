# ── Application ──────────────────────────────────────────────────
APP_NAME=WealthWise AI
APP_ENV=development
APP_PORT=8000
APP_DEBUG=false
SECRET_KEY=CHANGE_ME_TO_64_CHAR_RANDOM_HEX_STRING

# ── Database ──────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=wealthwise_db
POSTGRES_USER=wealthwise_user
# Must match the `postgres` service's POSTGRES_PASSWORD in docker-compose.yml
# when using the bundled Docker Compose stack for local dev (devpassword123).
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# Assembled automatically if left empty:
DATABASE_URL=
DB_ECHO=false

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_TO_64_CHAR_RANDOM_HEX_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Google Gemini ─────────────────────────────────────────────────
GEMINI_API_KEY=your_google_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=8192
GEMINI_TEMPERATURE=0.7

# ── AWS S3 / MinIO ────────────────────────────────────────────────
# Leave S3_ENDPOINT_URL empty for real AWS; set it for MinIO dev
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin123
S3_BUCKET_NAME=wealthwise-statements
S3_REGION=us-east-1

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_AI_REQUESTS=10

# ── File Upload ───────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=application/pdf,text/csv

# ── CORS & Security ───────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
ALLOWED_HOSTS=localhost,127.0.0.1

# ── OCR (legacy manual/admin endpoints only — active pipeline uses Docling directly) ──
# Engine to use.  Current: easyocr | Planned: paddleocr, aws_textract, azure_ocr
OCR_PROVIDER=easyocr
# Comma-separated language codes recognised by the active provider
OCR_LANGUAGE=en
# Set to true only if a CUDA-capable GPU is available in the runtime environment
OCR_GPU=false
# Confidence threshold [0.0–1.0]: text blocks below this are discarded
OCR_CONFIDENCE_THRESHOLD=0.5
